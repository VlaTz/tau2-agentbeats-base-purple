{
  manifest_version: "0.1.0",
  config_schema: {
    type: "object",
    properties: {
      agent_llm: { type: "string" },
      openai_api_key: { type: "string", secret: true },
      gemini_api_key: { type: "string", secret: true },
      deepseek_api_key: { type: "string", secret: true },
    },
    required: ["agent_llm"],
    additionalProperties: false,
  },
  slots: {
    proxy: { kind: "a2a", optional: true },
  },
  program: {
    image: "ghcr.io/andrew7234/tau2-agentbeats-base-purple:latest",
    entrypoint: ["uv", "run", "src/server.py", "--host", "0.0.0.0", "--port", "9009"],
    env: {
      AGENT_LLM: "${config.agent_llm}",
      OPENAI_API_KEY: "${config.openai_api_key}",
      GEMINI_API_KEY: "${config.gemini_api_key}",
      DEEPSEEK_API_KEY: "${config.deepseek_api_key}",
      LOG_LEVEL: "INFO",
    },
    network: {
      endpoints: [
        { name: "endpoint", port: 9009 }
      ]
    }
  },
  provides: {
    a2a: { kind: "a2a", endpoint: "endpoint" }
  },
  exports: {
    a2a: "a2a"
  }
}
